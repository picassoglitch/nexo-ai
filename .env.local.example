# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Mercado Pago (v1) — added in step 05
# MERCADOPAGO_ACCESS_TOKEN=
# MERCADOPAGO_PUBLIC_KEY=
# MERCADOPAGO_WEBHOOK_SECRET=

# Resend — transactional email (contact form, receipts) AND, via Supabase
# custom SMTP, all auth emails (signup confirm, password reset, magic link).
# See docs/email/supabase-auth-setup.md for the Supabase-side wiring.
RESEND_API_KEY=
# Verified sender. Defaults to "Nexo AI <noreply@nexo-ai.world>" if unset.
# Keep identical to the sender configured in Supabase → Auth → SMTP.
# RESEND_FROM_EMAIL=Nexo AI <noreply@nexo-ai.world>
# Where the public /contacto form lands. Defaults to RESEND_FROM_EMAIL.
# RESEND_CONTACT_TO=

# Site — used for absolute links in server-sent emails. In production set this
# to https://nexo-ai.world on Vercel. (Auth email links use the Supabase
# Site URL + redirect allowlist, configured in the Supabase dashboard.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Command Center — comma-separated list of emails that are ALWAYS forced to SUPER_ADMIN
# regardless of stored role. The first-user-is-root backstop.
SUPER_ADMIN_EMAILS=picassoglitch@gmail.com
